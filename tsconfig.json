{
	"compilerOptions": {
		"strict": true,
		"target": "ESNext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"sourceMap": true,
		"rootDir": ".",
		"noEmitOnError": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"types": ["node", "vite/client"]
	}
}
